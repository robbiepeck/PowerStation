{
  "name": "powerstation",
  "productName": "PowerStation",
  "desktopName": "powerstation.desktop",
  "private": true,
  "version": "0.18.1",
  "description": "Local AI for your computer: guided model choice, an agent harness built for small models, and honest resource monitoring.",
  "author": "Robbie Peck",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "doctor": "node scripts/doctor.mjs",
    "install:mac": "node scripts/install-macos.mjs",
    "update:mac": "node scripts/update-macos.mjs",
    "diagnostics": "node scripts/diagnostics.mjs",
    "desktop:dev": "node scripts/desktop-dev.mjs",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "tsc -b && vite build",
    "build:electron": "tsc -p tsconfig.electron.json && node scripts/copy-electron-preload.mjs",
    "audit": "npm audit --audit-level=high",
    "lint": "eslint .",
    "test": "vitest run",
    "package:mac": "npm run build && electron-builder --mac --universal -c.mac.identity=- -c.mac.hardenedRuntime=false -c.mac.notarize=false",
    "package:mac:dir": "npm run build && electron-builder --mac --universal --dir -c.mac.identity=- -c.mac.hardenedRuntime=false -c.mac.notarize=false",
    "package:mac:local": "npm run build && electron-builder --mac --arm64 --dir --publish never -c.mac.identity=- -c.mac.hardenedRuntime=false -c.mac.notarize=false",
    "package:mac:signed": "npm run build && electron-builder --mac --universal -c.forceCodeSigning=true",
    "package:win": "npm run build && electron-builder --win --x64",
    "package:win:signed": "npm run build && electron-builder --win --x64 -c.forceCodeSigning=true",
    "package:win:dir": "npm run build && electron-builder --win --x64 --dir",
    "package:linux": "npm run build && electron-builder --linux --x64",
    "package:linux:dir": "npm run build && electron-builder --linux --x64 --dir"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "electron-updater": "^6.8.9",
    "fix-path": "^5.0.0",
    "lucide-react": "^1.17.0",
    "node-llama-cpp": "^3.19.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "systeminformation": "^5.31.16"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "playwright": "^1.60.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.powerstation.desktop",
    "productName": "PowerStation",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "robbiepeck",
        "repo": "PowerStation"
      }
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "catalog/**/*",
      "skills/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/node-llama-cpp/**",
      "node_modules/@node-llama-cpp/**"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "notarize": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}-macOS-${arch}.${ext}"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "build/icons",
      "category": "Development",
      "synopsis": "Local AI desktop workspace for open-weight models.",
      "description": "PowerStation recommends, downloads, and runs local open-weight models with an agent harness, guarded tools, and live resource monitoring.",
      "maintainer": "Robbie Peck",
      "vendor": "Robbie Peck",
      "syncDesktopName": true,
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "desktop": {
        "entry": {
          "Comment": "Local AI desktop workspace for open-weight models"
        }
      }
    },
    "nsis": {
      "artifactName": "${productName}-${version}-Windows-Setup-${arch}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-Windows-Portable-${arch}.${ext}"
    },
    "appImage": {
      "artifactName": "${productName}-${version}-Linux-AppImage-${arch}.${ext}"
    },
    "deb": {
      "artifactName": "${productName}-${version}-Linux-${arch}.${ext}",
      "packageName": "powerstation",
      "packageCategory": "devel"
    }
  }
}
